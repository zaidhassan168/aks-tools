#!/usr/bin/env bash
# kit — Kubernetes Interactive Toolkit for AKS.
# Combines the old aksc (rails console) and aksm (pods/logs/configmaps) into one CLI.
# Same picker flow: subscription -> cluster -> namespace -> action.
# No global `az account set`. Unique kube context per subscription+cluster.

set -euo pipefail

# ---------- Setup ----------
need() { command -v "$1" >/dev/null 2>&1 || { echo "Missing dependency: $1" >&2; exit 1; }; }
need kubectl
need az
need python3

KUBECTL="kubectl"
KUBE_CTX=""
SUB_ID=""
CLUSTER_NAME=""
CLUSTER_RG=""
NAMESPACE=""

# Console-specific
KEEP_POD="${KEEP_POD:-0}"
ATTACH_MODE="${KIT_ATTACH_MODE:-attach}"
CONSOLE_POD=""
CONSOLE_NS=""
CONSOLE_CTX=""
CONSOLE_SUCCESS=0

die() { echo "Error: $*" >&2; exit 1; }
has_fzf() { command -v fzf >/dev/null 2>&1; }

# Pager: less so the user can scroll/select/copy. -R raw colours, -X keep on screen
# after quit, -F auto-quit if output fits one page.
pager() { less -RXF; }

# ---------- Pickers ----------

pick_subscription() {
  echo "Fetching Azure subscriptions..." >&2
  local ids=() names=()
  while IFS=$'\t' read -r id name; do
    [[ -n "$id" ]] || continue
    ids+=("$id"); names+=("$name")
  done <<EOF
$(az account list --query "[].{id:id, name:name}" -o tsv 2>/dev/null || true)
EOF
  ((${#ids[@]})) || die "No Azure subscriptions found. Run: az login"
  if ((${#ids[@]}==1)); then echo "${ids[0]}"; return; fi
  if has_fzf; then
    local selected
    selected="$(for i in "${!ids[@]}"; do printf "%s\t%s\n" "${names[$i]}" "${ids[$i]}"; done \
      | fzf --with-nth=1 --delimiter=$'\t' --prompt="Subscription > " --height=40% --reverse)"
    [[ -n "$selected" ]] || exit 1
    echo "$selected" | awk -F'\t' '{print $2}'
  else
    echo "Select subscription:" >&2
    for i in "${!ids[@]}"; do printf "%2d) %s (%s)\n" "$((i+1))" "${names[$i]}" "${ids[$i]}" >&2; done
    while true; do
      read -rp "> " n
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#ids[@]} )) && { echo "${ids[$((n-1))]}"; return; }
      echo "Invalid selection." >&2
    done
  fi
}

pick_aks_cluster() {
  local sub_id="$1"
  echo "Fetching AKS clusters..." >&2
  local err_file; err_file="$(mktemp)"
  local raw; raw="$(az aks list --subscription "$sub_id" --query "[].{name:name, rg:resourceGroup}" -o tsv 2>"$err_file" || true)"
  local err; err="$(cat "$err_file")"; rm -f "$err_file"
  local c_names=() c_rgs=()
  while IFS=$'\t' read -r name rg; do
    [[ -n "$name" ]] || continue
    c_names+=("$name"); c_rgs+=("$rg")
  done <<EOF
$raw
EOF
  if ((${#c_names[@]}==0)); then
    echo >&2
    echo "No AKS clusters visible in subscription $sub_id." >&2
    if [[ -n "$err" ]]; then
      echo "az error: $err" >&2
    else
      echo "Likely cause: Reader role on this subscription is not active." >&2
      echo "Fix: Azure Portal -> PIM -> activate Reader, then: az account clear && az login" >&2
    fi
    exit 1
  fi
  if ((${#c_names[@]}==1)); then echo "${c_names[0]}|${c_rgs[0]}"; return; fi
  if has_fzf; then
    local selected
    selected="$(for i in "${!c_names[@]}"; do printf "%s\t%s\n" "${c_names[$i]}" "${c_rgs[$i]}"; done \
      | fzf --with-nth=1 --delimiter=$'\t' --prompt="Cluster > " --height=40% --reverse)"
    [[ -n "$selected" ]] || exit 1
    echo "$(echo "$selected" | awk -F'\t' '{print $1}')|$(echo "$selected" | awk -F'\t' '{print $2}')"
  else
    echo "Select cluster:" >&2
    for i in "${!c_names[@]}"; do printf "%2d) %s (RG: %s)\n" "$((i+1))" "${c_names[$i]}" "${c_rgs[$i]}" >&2; done
    while true; do
      read -rp "> " n
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#c_names[@]} )) && { echo "${c_names[$((n-1))]}|${c_rgs[$((n-1))]}"; return; }
      echo "Invalid selection." >&2
    done
  fi
}

list_ns() { $KUBECTL --context "$KUBE_CTX" get ns -o custom-columns=NAME:.metadata.name --no-headers; }

pick_ns() {
  if has_fzf; then
    list_ns | fzf --prompt="Namespace > " --height=40% --reverse
  else
    local items=()
    while IFS= read -r line; do [[ -n "$line" ]] && items+=("$line"); done <<EOF
$(list_ns)
EOF
    ((${#items[@]})) || die "No namespaces found."
    echo "Select a namespace:" >&2
    for i in "${!items[@]}"; do printf "%2d) %s\n" "$((i+1))" "${items[$i]}" >&2; done
    while true; do
      read -rp "> " n
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#items[@]} )) && { echo "${items[$((n-1))]}"; return; }
      echo "Invalid selection." >&2
    done
  fi
}

pick_pod() {
  local ns="$1"
  local pods=()
  while IFS= read -r line; do [[ -n "$line" ]] && pods+=("$line"); done <<EOF
$($KUBECTL --context "$KUBE_CTX" -n "$ns" get pods -o custom-columns=NAME:.metadata.name,STATUS:.status.phase,RESTARTS:.status.containerStatuses[0].restartCount --no-headers 2>/dev/null || true)
EOF
  ((${#pods[@]})) || die "No pods found in $ns"
  if has_fzf; then
    printf "%s\n" "${pods[@]}" | fzf --prompt="Pod > " --height=40% --reverse | awk '{print $1}'
  else
    echo "Select a pod:" >&2
    for i in "${!pods[@]}"; do printf "%2d) %s\n" "$((i+1))" "${pods[$i]}" >&2; done
    while true; do
      read -rp "> " n
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#pods[@]} )) && { echo "${pods[$((n-1))]}" | awk '{print $1}'; return; }
      echo "Invalid selection." >&2
    done
  fi
}

pick_configmap() {
  local ns="$1"
  local cms=()
  while IFS= read -r line; do [[ -n "$line" ]] && cms+=("$line"); done <<EOF
$($KUBECTL --context "$KUBE_CTX" -n "$ns" get cm -o custom-columns=NAME:.metadata.name --no-headers 2>/dev/null | grep -v kube-root-ca || true)
EOF
  ((${#cms[@]})) || die "No configmaps found in $ns"
  if ((${#cms[@]}==1)); then echo "${cms[0]}"; return; fi
  if has_fzf; then
    printf "%s\n" "${cms[@]}" | fzf --prompt="ConfigMap > " --height=40% --reverse
  else
    echo "Select a ConfigMap:" >&2
    for i in "${!cms[@]}"; do printf "%2d) %s\n" "$((i+1))" "${cms[$i]}" >&2; done
    while true; do
      read -rp "> " n
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#cms[@]} )) && { echo "${cms[$((n-1))]}"; return; }
      echo "Invalid selection." >&2
    done
  fi
}

pick_deployment() {
  local ns="$1"
  local deploys=()
  while IFS= read -r d; do [[ -n "$d" ]] && deploys+=("$d"); done <<EOF
$($KUBECTL --context "$KUBE_CTX" -n "$ns" get deploy -o custom-columns=NAME:.metadata.name --no-headers 2>/dev/null || true)
EOF
  ((${#deploys[@]})) || die "No deployments found in $ns"
  if ((${#deploys[@]}==1)); then echo "${deploys[0]}"; return; fi
  if has_fzf; then
    printf "%s\n" "${deploys[@]}" | fzf --prompt="Deployment > " --height=40% --reverse
  else
    echo "Select deployment:" >&2
    for i in "${!deploys[@]}"; do printf "%2d) %s\n" "$((i+1))" "${deploys[$i]}" >&2; done
    while true; do
      read -rp "> " n
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#deploys[@]} )) && { echo "${deploys[$((n-1))]}"; return; }
      echo "Invalid selection." >&2
    done
  fi
}

# ---------- Credentials ----------

ensure_creds() {
  local sub_id="$1" rg="$2" cluster="$3" ctx="$4"
  echo "Getting AKS credentials for $cluster..." >&2
  local err
  if ! err="$(az aks get-credentials \
      --subscription "$sub_id" --resource-group "$rg" --name "$cluster" \
      --overwrite-existing --context "$ctx" 2>&1 >/dev/null)"; then
    echo "Error: Failed to get AKS credentials." >&2
    echo "$err" >&2
    exit 1
  fi
}

# ---------- Read commands (paged) ----------

cmd_pods() {
  local ns="$1"
  {
    echo "=== Pods in $ns ==="
    $KUBECTL --context "$KUBE_CTX" -n "$ns" get pods -o wide
  } | pager
}

cmd_logs() {
  local ns="$1"
  local pod; pod="$(pick_pod "$ns")" || return 1
  [[ -n "$pod" ]] || return 1
  local tail="${2:-200}"
  {
    echo "=== Logs for $pod (tail $tail) ==="
    $KUBECTL --context "$KUBE_CTX" -n "$ns" logs "$pod" --tail="$tail" --all-containers=true
  } | pager
}

cmd_logs_follow() {
  local ns="$1"
  local pod; pod="$(pick_pod "$ns")" || return 1
  [[ -n "$pod" ]] || return 1
  echo "=== Following logs for $pod (Ctrl+C to stop) ==="
  $KUBECTL --context "$KUBE_CTX" -n "$ns" logs "$pod" -f --all-containers=true || true
}

cmd_describe() {
  local ns="$1"
  local pod; pod="$(pick_pod "$ns")" || return 1
  [[ -n "$pod" ]] || return 1
  $KUBECTL --context "$KUBE_CTX" -n "$ns" describe pod "$pod" | pager
}

cmd_events() {
  local ns="$1"
  {
    echo "=== Recent events in $ns ==="
    $KUBECTL --context "$KUBE_CTX" -n "$ns" get events --sort-by=.lastTimestamp | tail -50
  } | pager
}

cmd_cm_view() {
  local ns="$1"
  local cm; cm="$(pick_configmap "$ns")" || return 1
  [[ -n "$cm" ]] || return 1
  {
    echo "=== ConfigMap: $cm ==="
    $KUBECTL --context "$KUBE_CTX" -n "$ns" get cm "$cm" -o yaml
  } | pager
}

cmd_cm_get() {
  local ns="$1"
  local cm; cm="$(pick_configmap "$ns")" || return 1
  [[ -n "$cm" ]] || return 1
  {
    echo "=== ConfigMap: $cm (data only) ==="
    $KUBECTL --context "$KUBE_CTX" -n "$ns" get cm "$cm" -o jsonpath='{.data}' \
      | python3 -m json.tool 2>/dev/null \
      || $KUBECTL --context "$KUBE_CTX" -n "$ns" get cm "$cm" -o jsonpath='{.data}'
    echo
  } | pager
}

# ---------- Mutating commands ----------

cmd_cm_set() {
  local ns="$1"
  local cm; cm="$(pick_configmap "$ns")" || return 1
  [[ -n "$cm" ]] || return 1
  echo "Set configmap values (KEY=VALUE). Empty line to finish."
  local patch_data="{" first=1
  while true; do
    read -rp "  KEY=VALUE> " kv
    [[ -z "$kv" ]] && break
    if [[ "$kv" != *"="* ]]; then echo "  Invalid format. Use KEY=VALUE" >&2; continue; fi
    local key="${kv%%=*}" val="${kv#*=}"
    [[ $first -eq 1 ]] && first=0 || patch_data+=","
    val="${val//\"/\\\"}"
    patch_data+="\"$key\":\"$val\""
  done
  patch_data+="}"
  if [[ "$patch_data" == "{}" ]]; then echo "No values provided, skipping." >&2; return; fi
  echo
  echo "Patching $cm with: $patch_data"
  read -rp "Confirm? (y/n) > " confirm
  if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
    $KUBECTL --context "$KUBE_CTX" -n "$ns" patch configmap "$cm" --type merge -p "{\"data\":$patch_data}"
    echo "Done. Run 'kit restart' to apply changes."
  else
    echo "Cancelled."
  fi
}

cmd_cm_del() {
  local ns="$1"
  local cm; cm="$(pick_configmap "$ns")" || return 1
  [[ -n "$cm" ]] || return 1
  echo "Current keys in $cm:"
  local keys=()
  while IFS= read -r k; do [[ -n "$k" ]] && keys+=("$k"); done <<EOF
$($KUBECTL --context "$KUBE_CTX" -n "$ns" get cm "$cm" -o json 2>/dev/null \
  | python3 -c 'import sys,json; print("\n".join(json.load(sys.stdin).get("data",{}).keys()))')
EOF
  ((${#keys[@]})) || { echo "No keys in this configmap." >&2; return; }
  local key
  if has_fzf; then
    key="$(printf "%s\n" "${keys[@]}" | fzf --prompt="Key to delete > " --height=40% --reverse)"
  else
    for i in "${!keys[@]}"; do printf "%2d) %s\n" "$((i+1))" "${keys[$i]}" >&2; done
    read -rp "Key number > " n
    [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#keys[@]} )) && key="${keys[$((n-1))]}"
  fi
  [[ -n "${key:-}" ]] || return
  read -rp "Delete key '$key' from $cm? (y/n) > " confirm
  if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
    $KUBECTL --context "$KUBE_CTX" -n "$ns" patch configmap "$cm" --type json -p "[{\"op\":\"remove\",\"path\":\"/data/$key\"}]"
    echo "Deleted '$key'. Run 'kit restart' to apply."
  fi
}

cmd_restart() {
  local ns="$1"
  local deploy; deploy="$(pick_deployment "$ns")" || return 1
  [[ -n "$deploy" ]] || return 1
  echo "Restarting deployment $deploy..."
  $KUBECTL --context "$KUBE_CTX" -n "$ns" rollout restart deployment "$deploy"
  echo "Watching rollout..."
  $KUBECTL --context "$KUBE_CTX" -n "$ns" rollout status deployment "$deploy" --timeout=180s || true
}

cmd_exec() {
  local ns="$1"
  local pod; pod="$(pick_pod "$ns")" || return 1
  [[ -n "$pod" ]] || return 1
  echo "Opening shell in $pod (Ctrl+D to exit)..."
  $KUBECTL --context "$KUBE_CTX" -n "$ns" exec -it "$pod" -- /bin/sh -c 'command -v bash >/dev/null && exec bash || exec sh' || true
}

# ---------- Rails console (from old aksc) ----------

console_cleanup() {
  [[ -n "$CONSOLE_POD" && -n "$CONSOLE_NS" && -n "$CONSOLE_CTX" ]] || return 0
  if [[ "$CONSOLE_SUCCESS" -ne 0 && "$KEEP_POD" -eq 1 ]]; then
    echo
    echo "KEEP_POD=1 set, not deleting failed pod: $CONSOLE_POD"
    CONSOLE_POD=""; CONSOLE_NS=""; CONSOLE_CTX=""
    return 0
  fi
  echo
  echo "Cleaning up pod $CONSOLE_POD..."
  $KUBECTL --context "$CONSOLE_CTX" -n "$CONSOLE_NS" delete pod "$CONSOLE_POD" --wait=false >/dev/null 2>&1 || true
  CONSOLE_POD=""; CONSOLE_NS=""; CONSOLE_CTX=""
}

console_print_debug() {
  local ns="$1" pod="$2"
  echo
  echo "==================== POD DEBUG ===================="
  echo "Context:   $KUBE_CTX"
  echo "Namespace: $ns"
  echo "Pod:       $pod"
  echo "---------------------------------------------------"
  $KUBECTL --context "$KUBE_CTX" -n "$ns" get pod "$pod" -o wide || true
  echo
  echo "---- describe ----"
  $KUBECTL --context "$KUBE_CTX" -n "$ns" describe pod "$pod" || true
  echo
  echo "---- recent events ----"
  $KUBECTL --context "$KUBE_CTX" -n "$ns" get events --sort-by=.lastTimestamp | tail -n 40 || true
  echo
  echo "---- logs (all containers) ----"
  local pod_json containers
  pod_json="$($KUBECTL --context "$KUBE_CTX" -n "$ns" get pod "$pod" -o json 2>/dev/null || true)"
  [[ -n "$pod_json" ]] || { echo "Could not fetch pod JSON." >&2; return 0; }
  containers="$(printf '%s' "$pod_json" | python3 - <<'PY'
import sys, json
d=json.load(sys.stdin)
names=[]
for c in (d.get("spec", {}).get("initContainers") or []):
  if c.get("name"): names.append(c["name"])
for c in (d.get("spec", {}).get("containers") or []):
  if c.get("name"): names.append(c["name"])
print("\n".join(names))
PY
)"
  while IFS= read -r cname; do
    [[ -n "$cname" ]] || continue
    echo
    echo ">>> $cname (current) [tail 200]"
    $KUBECTL --context "$KUBE_CTX" -n "$ns" logs "$pod" -c "$cname" --tail=200 2>/dev/null || true
    echo
    echo ">>> $cname (previous) [tail 200]"
    $KUBECTL --context "$KUBE_CTX" -n "$ns" logs "$pod" -c "$cname" --previous --tail=200 2>/dev/null || true
  done <<EOF
$containers
EOF
  echo "==================================================="
}

cmd_console() {
  local ns="$1"
  local mode="${2:-$ATTACH_MODE}"

  $KUBECTL --context "$KUBE_CTX" get ns "$ns" >/dev/null 2>&1 || die "Namespace '$ns' not found."

  # Detect image
  local IMG="" dep_imgs=()
  while IFS= read -r line; do [[ -n "$line" ]] && dep_imgs+=("$line"); done <<EOF
$($KUBECTL --context "$KUBE_CTX" -n "$ns" get deploy \
  -o jsonpath='{range .items[*]}{range .spec.template.spec.containers[*]}{.image}{"\n"}{end}{end}' 2>/dev/null \
  | sed '/^\s*$/d' | sort -u || true)
EOF
  ((${#dep_imgs[@]})) || die "Could not detect an image in '$ns' (no deployments?)."
  for i in "${dep_imgs[@]}"; do [[ "$i" == *".azurecr.io/"* ]] && { IMG="$i"; break; }; done
  [[ -z "$IMG" ]] && IMG="${dep_imgs[0]}"

  # Detect ConfigMap
  local CM=""
  if $KUBECTL --context "$KUBE_CTX" -n "$ns" get cm "${ns}-config" >/dev/null 2>&1; then
    CM="${ns}-config"
  else
    local cms=()
    while IFS= read -r line; do [[ -n "$line" ]] && cms+=("$line"); done <<EOF
$($KUBECTL --context "$KUBE_CTX" -n "$ns" get cm -o custom-columns=NAME:.metadata.name --no-headers 2>/dev/null | grep -Ei 'config|env' || true)
EOF
    if ((${#cms[@]}==1)); then
      CM="${cms[0]}"
    elif ((${#cms[@]}>1)); then
      if has_fzf; then
        CM="$(printf "%s\n" "${cms[@]}" | fzf --prompt="ConfigMap > " --height=40% --reverse)"
      else
        for i in "${!cms[@]}"; do printf "%2d) %s\n" "$((i+1))" "${cms[$i]}" >&2; done
        read -rp "> " m
        [[ "$m" =~ ^[0-9]+$ ]] && (( m>=1 && m<=${#cms[@]} )) && CM="${cms[$((m-1))]}"
      fi
    fi
  fi

  # Copy scheduling from a real Running app pod
  local IMG_NO_DIGEST="${IMG%@*}"
  local REPO="${IMG_NO_DIGEST%:*}"
  local REF_POD
  REF_POD="$(
    $KUBECTL --context "$KUBE_CTX" -n "$ns" get pods \
      -o jsonpath='{range .items[?(@.status.phase=="Running")]}{.metadata.name}{"\t"}{range .spec.containers[*]}{.image}{" "}{end}{"\n"}{end}' \
    | awk -v repo="$REPO" '$0 ~ repo {print $1; exit}'
  )"
  if [[ -z "$REF_POD" ]]; then
    REF_POD="$(
      $KUBECTL --context "$KUBE_CTX" -n "$ns" get pods \
        -o jsonpath='{range .items[?(@.status.phase=="Running")]}{.metadata.name}{"\t"}{.metadata.ownerReferences[0].kind}{"\n"}{end}' \
      | awk '$2=="ReplicaSet"{print $1; exit}'
    )"
  fi
  [[ -n "$REF_POD" ]] || die "No suitable Running pod found in $ns to copy scheduling from."

  local REF_JSON SVC_ACCOUNT NODESELECTOR_JSON TOLERATIONS_JSON AFFINITY_JSON
  REF_JSON="$($KUBECTL --context "$KUBE_CTX" -n "$ns" get pod "$REF_POD" -o json)"
  SVC_ACCOUNT="$(printf '%s' "$REF_JSON" | python3 -c 'import sys,json; d=json.load(sys.stdin); print(d.get("spec",{}).get("serviceAccountName","default"))')"
  NODESELECTOR_JSON="$(printf '%s' "$REF_JSON" | python3 -c 'import sys,json,json as j; d=json.load(sys.stdin); print(j.dumps(d.get("spec",{}).get("nodeSelector") or {}))')"
  TOLERATIONS_JSON="$(printf '%s' "$REF_JSON" | python3 -c 'import sys,json,json as j; d=json.load(sys.stdin); print(j.dumps(d.get("spec",{}).get("tolerations") or []))')"
  AFFINITY_JSON="$(printf '%s' "$REF_JSON" | python3 -c 'import sys,json,json as j; d=json.load(sys.stdin); print(j.dumps(d.get("spec",{}).get("affinity") or {}))')"

  local USER_NAME TS POD_NAME
  USER_NAME="$(id -un 2>/dev/null || whoami)"
  TS="$(date +%s)"
  POD_NAME="rails-console-${USER_NAME}-${TS}"

  local POD_COMMAND='["/cnb/lifecycle/launcher"]' POD_ARGS
  if [[ "$mode" == "exec" ]]; then
    POD_ARGS='["sleep","infinity"]'
  else
    POD_ARGS='["bundle","exec","rails","console"]'
  fi

  local ENVFROM=""
  if [[ -n "${CM:-}" ]]; then
    ENVFROM=$(cat <<YML
      envFrom:
        - configMapRef:
            name: $CM
YML
)
  fi

  # Register cleanup before pod creation so trap fires even if apply succeeds and next step fails
  CONSOLE_POD="$POD_NAME"
  CONSOLE_NS="$ns"
  CONSOLE_CTX="$KUBE_CTX"
  trap console_cleanup EXIT

  cat <<EOF | $KUBECTL --context "$KUBE_CTX" -n "$ns" apply -f - >/dev/null
apiVersion: v1
kind: Pod
metadata:
  name: $POD_NAME
  labels:
    app: rails-console
spec:
  restartPolicy: Never
  terminationGracePeriodSeconds: 0
  serviceAccountName: $SVC_ACCOUNT
  nodeSelector: $NODESELECTOR_JSON
  tolerations: $TOLERATIONS_JSON
  affinity: $AFFINITY_JSON
  containers:
    - name: rails-console
      image: $IMG
      command: $POD_COMMAND
      args: $POD_ARGS
$ENVFROM
      env:
        - name: NEW_RELIC_AGENT_ENABLED
          value: "false"
      stdin: true
      tty: true
EOF

  echo
  echo "Context:   $KUBE_CTX"
  echo "Namespace: $ns"
  echo "Image:     $IMG"
  echo "ConfigMap: ${CM:-<none>}"
  echo "Ref pod:   $REF_POD"
  echo "Pod:       $POD_NAME"
  echo "Mode:      $mode"
  echo

  echo "Waiting for pod to be Ready..."
  local deadline=$(( $(date +%s) + 180 )) phase ready
  while true; do
    phase="$($KUBECTL --context "$KUBE_CTX" -n "$ns" get pod "$POD_NAME" -o jsonpath='{.status.phase}' 2>/dev/null || echo Unknown)"
    if [[ "$phase" == "Running" ]]; then
      ready="$($KUBECTL --context "$KUBE_CTX" -n "$ns" get pod "$POD_NAME" -o jsonpath='{range .status.conditions[?(@.type=="Ready")]}{.status}{end}' 2>/dev/null || true)"
      [[ "$ready" == "True" ]] && break
    fi
    if [[ "$phase" == "Failed" || "$phase" == "Succeeded" ]]; then
      CONSOLE_SUCCESS=1
      echo "Pod phase became $phase before Ready." >&2
      console_print_debug "$ns" "$POD_NAME"
      return 1
    fi
    if (( $(date +%s) > deadline )); then
      CONSOLE_SUCCESS=1
      echo "Timed out waiting for pod to become Ready." >&2
      console_print_debug "$ns" "$POD_NAME"
      return 1
    fi
    sleep 2
  done

  echo "Pod is Ready. Connecting to Rails console."
  local rc=0
  if [[ "$mode" == "exec" ]]; then
    $KUBECTL --context "$KUBE_CTX" -n "$ns" exec -it "pod/$POD_NAME" -c rails-console -- /cnb/lifecycle/launcher bundle exec rails console || rc=$?
  else
    echo "Using attach mode. If no prompt appears, exit and re-run with KIT_ATTACH_MODE=exec."
    $KUBECTL --context "$KUBE_CTX" -n "$ns" attach -it "pod/$POD_NAME" -c rails-console || rc=$?
  fi

  if (( rc != 0 )); then
    CONSOLE_SUCCESS=1
    console_print_debug "$ns" "$POD_NAME"
  else
    CONSOLE_SUCCESS=0
  fi

  # Always delete the pod now (don't wait for the EXIT trap so we don't leak
  # pods across multiple console invocations in the same kit session).
  console_cleanup
  trap - EXIT
  return $rc
}

# ---------- Admin: orphaned console pods ----------

cmd_orphan_list() {
  local user_name="${1:-$(id -un 2>/dev/null || whoami)}"
  local pattern="rails-console-${user_name}-"
  echo "Searching for orphaned Rails console pods created by: $user_name" >&2

  local contexts=()
  while IFS= read -r ctx; do
    [[ -n "$ctx" ]] && contexts+=("$ctx")
  done < <(kubectl config get-contexts -o name 2>/dev/null | grep -E '^(aksc|kit)-' || true)

  if ((${#contexts[@]}==0)); then
    echo "No kit/aksc contexts found. Run 'kit' once to create them." >&2
    return 0
  fi

  local found=0
  for ctx in "${contexts[@]}"; do
    local namespaces=()
    while IFS= read -r ns; do [[ -n "$ns" ]] && namespaces+=("$ns"); done \
      < <(kubectl --context "$ctx" get ns -o custom-columns=NAME:.metadata.name --no-headers 2>/dev/null || true)
    for ns in "${namespaces[@]}"; do
      local pods_info
      pods_info="$(kubectl --context "$ctx" -n "$ns" get pods \
        -o custom-columns=NAME:.metadata.name,STATUS:.status.phase --no-headers 2>/dev/null \
        | grep "^$pattern" || true)"
      if [[ -n "$pods_info" ]]; then
        if [[ $found -eq 0 ]]; then
          printf "%-50s %-30s %-15s %s\n" "CONTEXT" "NAMESPACE" "STATUS" "POD"
          printf '=%.0s' {1..120}; echo
          found=1
        fi
        while IFS= read -r line; do
          [[ -z "$line" ]] && continue
          local pod_name status
          pod_name="$(echo "$line" | awk '{print $1}')"
          status="$(echo "$line" | awk '{print $2}')"
          printf "%-50s %-30s %-15s %s\n" "$ctx" "$ns" "$status" "$pod_name"
        done <<< "$pods_info"
      fi
    done
  done

  if [[ $found -eq 0 ]]; then
    echo "No orphaned Rails console pods found for user: $user_name" >&2
  else
    echo >&2
    echo "Run 'kit cleanup' to delete all orphaned pods owned by $user_name." >&2
  fi
}

cmd_orphan_clean() {
  local user_name="${1:-$(id -un 2>/dev/null || whoami)}"
  local pattern="rails-console-${user_name}-"
  echo "Cleaning up all orphaned Rails console pods for: $user_name" >&2

  local contexts=()
  while IFS= read -r ctx; do
    [[ -n "$ctx" ]] && contexts+=("$ctx")
  done < <(kubectl config get-contexts -o name 2>/dev/null | grep -E '^(aksc|kit)-' || true)

  if ((${#contexts[@]}==0)); then echo "No kit/aksc contexts found." >&2; return 0; fi

  local deleted=0
  for ctx in "${contexts[@]}"; do
    local namespaces=()
    while IFS= read -r ns; do [[ -n "$ns" ]] && namespaces+=("$ns"); done \
      < <(kubectl --context "$ctx" get ns -o custom-columns=NAME:.metadata.name --no-headers 2>/dev/null || true)
    for ns in "${namespaces[@]}"; do
      local pods
      pods="$(kubectl --context "$ctx" -n "$ns" get pods \
        -o custom-columns=NAME:.metadata.name --no-headers 2>/dev/null \
        | grep "^$pattern" || true)"
      while IFS= read -r pod; do
        [[ -z "$pod" ]] && continue
        echo "Deleting: $pod (context: $ctx, namespace: $ns)" >&2
        kubectl --context "$ctx" -n "$ns" delete pod "$pod" --wait=false >/dev/null 2>&1 \
          || echo "  Failed to delete $pod" >&2
        deleted=$((deleted + 1))
      done <<< "$pods"
    done
  done

  if [[ $deleted -eq 0 ]]; then
    echo "No orphaned pods found to clean up." >&2
  else
    echo "Deleted $deleted orphaned pod(s)." >&2
  fi
}

# ---------- Stale pod scan ----------

# Pick a deployment, then list its stale pods (Succeeded / Failed / Evicted /
# stuck Terminating) in a multi-select picker, confirm, and delete only the
# chosen ones. Scoping is by deployment, not by whole namespace, so you won't
# accidentally touch pods from other apps sharing the namespace.
cmd_stale() {
  local ns="$1"
  local deploy; deploy="$(pick_deployment "$ns")" || return 1
  [[ -n "$deploy" ]] || return 1

  local selector
  selector="$($KUBECTL --context "$KUBE_CTX" -n "$ns" get deployment "$deploy" -o json 2>/dev/null \
    | python3 -c '
import sys, json
try:
    d = json.load(sys.stdin)
except Exception:
    d = {}
ml = (d.get("spec", {}) or {}).get("selector", {}).get("matchLabels", {}) or {}
print(",".join(f"{k}={v}" for k, v in ml.items()))
')"

  if [[ -z "$selector" ]]; then
    echo "Could not read selector labels from deployment '$deploy'." >&2
    return 1
  fi

  echo "Scanning deployment '$deploy' in '$ns' (selector: $selector)..." >&2

  local pods_json
  pods_json="$($KUBECTL --context "$KUBE_CTX" -n "$ns" get pods -l "$selector" -o json 2>/dev/null || true)"
  [[ -z "$pods_json" ]] && pods_json='{"items":[]}'

  local stale_tsv
  stale_tsv="$(printf '%s' "$pods_json" | python3 - <<'PY'
import sys, json
from datetime import datetime, timezone

STUCK_TERMINATING_MIN = 5

def parse_ts(s):
    if not s: return None
    return datetime.fromisoformat(s.replace('Z', '+00:00'))

def age_str(td):
    s = int(td.total_seconds())
    if s < 60: return f"{s}s"
    if s < 3600: return f"{s//60}m"
    if s < 86400: return f"{s//3600}h"
    return f"{s//86400}d"

try:
    data = json.load(sys.stdin)
except Exception:
    data = {}
now = datetime.now(timezone.utc)
rows = []
for p in data.get("items", []):
    meta = p.get("metadata", {})
    status = p.get("status", {})
    name = meta.get("name", "")
    ns = meta.get("namespace", "")
    phase = status.get("phase", "")
    reason = status.get("reason", "")
    created = parse_ts(meta.get("creationTimestamp"))
    deleted = parse_ts(meta.get("deletionTimestamp"))
    owners = meta.get("ownerReferences") or []
    owned_by_job = any(o.get("kind") == "Job" for o in owners)

    flag = None
    if reason == "Evicted":
        flag = "Evicted"
    elif phase == "Failed":
        flag = f"Failed({reason})" if reason else "Failed"
    elif phase == "Succeeded" and not owned_by_job:
        flag = "Succeeded"
    elif deleted and (now - deleted).total_seconds() > STUCK_TERMINATING_MIN * 60:
        flag = f"Terminating>{STUCK_TERMINATING_MIN}m"

    if flag:
        age = age_str(now - created) if created else "?"
        rows.append("\t".join([ns, name, phase or "-", age, flag]))

print("\n".join(rows))
PY
)"

  if [[ -z "$stale_tsv" ]]; then
    echo "No stale pods found." >&2
    return 0
  fi

  local header
  header=$'NAMESPACE\tPOD\tSTATUS\tAGE\tREASON'

  local selected=""
  if has_fzf; then
    selected="$({ printf '%s\n' "$header"; printf '%s\n' "$stale_tsv"; } \
      | column -t -s $'\t' \
      | fzf --multi --header-lines=1 \
            --prompt="Stale pods (Tab to mark, Enter to confirm) > " \
            --height=70% --reverse)"
  else
    local lines=()
    while IFS= read -r line; do [[ -n "$line" ]] && lines+=("$line"); done <<EOF
$stale_tsv
EOF
    echo "Stale pods:" >&2
    {
      printf '  #\t%s\n' "$header"
      for i in "${!lines[@]}"; do printf '%3d\t%s\n' "$((i+1))" "${lines[$i]}"; done
    } | column -t -s $'\t' >&2
    echo >&2
    read -rp "Select numbers to delete (comma-separated, e.g. 1,3,5; empty to cancel) > " picks
    [[ -z "$picks" ]] && { echo "Cancelled." >&2; return 0; }
    IFS=',' read -ra nums <<< "$picks"
    for n in "${nums[@]}"; do
      n="$(echo "$n" | tr -d ' ')"
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#lines[@]} )) && selected+="${lines[$((n-1))]}"$'\n'
    done
  fi

  [[ -z "$selected" ]] && { echo "No pods selected." >&2; return 0; }

  # Parse back: first whitespace-separated field is namespace, second is pod name.
  # (column -t pads with spaces; neither ns nor pod names contain whitespace.)
  local to_delete=()
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    local ns_col pod_col
    ns_col="$(echo "$line" | awk '{print $1}')"
    pod_col="$(echo "$line" | awk '{print $2}')"
    [[ -n "$ns_col" && -n "$pod_col" ]] && to_delete+=("$ns_col|$pod_col")
  done <<EOF
$selected
EOF

  ((${#to_delete[@]})) || { echo "No pods selected." >&2; return 0; }

  echo
  echo "Will delete ${#to_delete[@]} pod(s):"
  local entry
  for entry in "${to_delete[@]}"; do
    echo "  - ${entry##*|} (ns: ${entry%%|*})"
  done
  read -rp "Confirm? (y/n) > " confirm
  [[ "$confirm" == "y" || "$confirm" == "Y" ]] || { echo "Cancelled."; return 0; }

  for entry in "${to_delete[@]}"; do
    local ns_p="${entry%%|*}" pod_p="${entry##*|}"
    echo "Deleting $pod_p (ns: $ns_p)..."
    $KUBECTL --context "$KUBE_CTX" -n "$ns_p" delete pod "$pod_p" --wait=false >/dev/null 2>&1 \
      || echo "  Failed to delete $pod_p" >&2
  done
  echo "Done."
}

# ---------- Action menu ----------

pick_action() {
  local actions=(
    "pods         — List all pods"
    "logs         — View pod logs (paged)"
    "logs-f       — Follow pod logs (live)"
    "describe     — Describe a pod"
    "events       — Recent namespace events"
    "exec         — Shell into a pod"
    "console      — Rails console (new pod)"
    "cm-view      — View configmap (full yaml)"
    "cm-get       — View configmap data"
    "cm-set       — Add/update configmap values"
    "cm-del       — Delete a configmap key"
    "restart      — Restart a deployment"
    "stale        — Pick deployment, list its stale pods, delete selected"
    "back-ns      — Change namespace"
    "back-cluster — Change cluster"
    "back-sub     — Change subscription"
    "quit         — Exit"
  )
  if has_fzf; then
    printf "%s\n" "${actions[@]}" | fzf --prompt="Action > " --height=50% --reverse | awk '{print $1}'
  else
    echo "Select action:" >&2
    for i in "${!actions[@]}"; do printf "%2d) %s\n" "$((i+1))" "${actions[$i]}" >&2; done
    while true; do
      read -rp "> " n
      [[ "$n" =~ ^[0-9]+$ ]] && (( n>=1 && n<=${#actions[@]} )) && { echo "${actions[$((n-1))]}" | awk '{print $1}'; return; }
      echo "Invalid selection." >&2
    done
  fi
}

run_action() {
  local action="$1" ns="$2"
  case "$action" in
    pods)         cmd_pods "$ns" ;;
    logs)         cmd_logs "$ns" ;;
    logs-f|logs-follow) cmd_logs_follow "$ns" ;;
    describe)     cmd_describe "$ns" ;;
    events)       cmd_events "$ns" ;;
    exec)         cmd_exec "$ns" ;;
    console)      cmd_console "$ns" "$ATTACH_MODE" ;;
    cm-view)      cmd_cm_view "$ns" ;;
    cm-get)       cmd_cm_get "$ns" ;;
    cm-set)       cmd_cm_set "$ns" ;;
    cm-del)       cmd_cm_del "$ns" ;;
    restart)      cmd_restart "$ns" ;;
    stale)        cmd_stale "$ns" ;;
    *)            echo "Unknown action: $action" >&2; return 1 ;;
  esac
}

# ---------- Help ----------

show_help() {
  cat <<HELP
kit — Kubernetes Interactive Toolkit for AKS

USAGE:
  kit                    Interactive mode (pick sub -> cluster -> ns -> action)
  kit <action>           Pick sub/cluster/ns then run action directly
  kit cleanup [USER]     Delete all orphaned Rails console pods (default: you)
  kit list-orphaned [USER]  List orphaned Rails console pods
  kit -h | --help        This help

ACTIONS:
  pods                   List all pods (paged)
  logs                   View pod logs (pick a pod, paged)
  logs-f                 Follow pod logs (live)
  describe               Describe a pod
  events                 Recent namespace events
  exec                   Open a shell in a running pod
  console                Spin up a Rails console pod (use KIT_ATTACH_MODE=exec if no prompt)
  cm-view                View ConfigMap as full yaml
  cm-get                 View ConfigMap data only
  cm-set                 Add/update ConfigMap values
  cm-del                 Delete a ConfigMap key
  restart                Rollout restart a deployment
  stale                  Pick a deployment, list its stale pods, Tab-select + delete

STALE HEURISTIC (scoped to the picked deployment's selector labels):
  A pod is flagged stale if any of:
    - status.reason == Evicted
    - phase == Failed
    - phase == Succeeded and not owned by a Job
    - deletionTimestamp set > 5 min ago (stuck Terminating)

NAVIGATION (interactive mode):
  back-ns, back-cluster, back-sub, quit

ENV:
  KEEP_POD=1             Keep failed Rails console pod for debugging
  KIT_ATTACH_MODE=exec   Default to exec mode for console

EXAMPLES:
  kit                    # full interactive flow
  kit logs               # jumps to pod picker after sub/cluster/ns
  kit console            # rails console (replaces aksc)
  kit cleanup            # delete your orphaned console pods
HELP
}

# ---------- Main ----------

# Top-level non-cluster commands
case "${1:-}" in
  -h|--help|help) show_help; exit 0 ;;
  cleanup|--cleanup-all|--cleanup) shift; cmd_orphan_clean "${1:-}"; exit 0 ;;
  list-orphaned|--list-orphaned|--list|-l) shift; cmd_orphan_list "${1:-}"; exit 0 ;;
esac

az account show >/dev/null 2>&1 || die "Not logged into Azure CLI. Run: az login"

# Direct subcommand mode: pick sub/cluster/ns once, run the action, exit.
if [[ -n "${1:-}" ]]; then
  ACTION="$1"

  SUB_ID="$(pick_subscription)"
  CLUSTER_INFO="$(pick_aks_cluster "$SUB_ID")"
  CLUSTER_NAME="${CLUSTER_INFO%%|*}"
  CLUSTER_RG="${CLUSTER_INFO##*|}"
  KUBE_CTX="kit-${SUB_ID:0:8}-${CLUSTER_NAME}"
  ensure_creds "$SUB_ID" "$CLUSTER_RG" "$CLUSTER_NAME" "$KUBE_CTX"
  NAMESPACE="$(pick_ns)"
  echo
  echo "Context:   $KUBE_CTX"
  echo "Namespace: $NAMESPACE"
  echo
  run_action "$ACTION" "$NAMESPACE"
  exit $?
fi

# Interactive mode: nested loops with back-navigation.
# Levels: subscription -> cluster -> namespace -> action.
while true; do  # SUB loop
  SUB_ID="$(pick_subscription)"

  while true; do  # CLUSTER loop
    CLUSTER_INFO="$(pick_aks_cluster "$SUB_ID")"
    CLUSTER_NAME="${CLUSTER_INFO%%|*}"
    CLUSTER_RG="${CLUSTER_INFO##*|}"
    KUBE_CTX="kit-${SUB_ID:0:8}-${CLUSTER_NAME}"
    ensure_creds "$SUB_ID" "$CLUSTER_RG" "$CLUSTER_NAME" "$KUBE_CTX"

    nav=""
    while true; do  # NS loop
      NAMESPACE="$(pick_ns)"
      echo
      echo "Context:   $KUBE_CTX"
      echo "Namespace: $NAMESPACE"
      echo

      nav=""
      while true; do  # ACTION loop
        ACTION="$(pick_action)"
        case "$ACTION" in
          back-ns)      nav="ns"; break ;;
          back-cluster) nav="cluster"; break ;;
          back-sub)     nav="sub"; break ;;
          quit|"")      echo "Bye!"; exit 0 ;;
          *)            run_action "$ACTION" "$NAMESPACE" || true ;;
        esac
        echo
      done

      [[ "$nav" == "ns" ]] && continue
      break
    done

    [[ "$nav" == "cluster" ]] && continue
    break
  done
done
